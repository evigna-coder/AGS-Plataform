rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Usuario autenticado (Google + dominio @agsanalitica.com validado en el cliente).
    // Las tres apps (sistema-modular, portal-ingeniero, reportes-ot) autentican antes de
    // tocar Firestore. Las Cloud Functions usan admin SDK y bypasean estas reglas.
    function signedIn() {
      return request.auth != null;
    }

    // ── Identidad de CLIENTE (custom claims, Fase B del plan seguridad-qr-cliente) ──
    // Un usuario CLIENTE tiene claim role == 'client' + clienteId. Cualquier otro
    // usuario autenticado es STAFF de AGS (acceso interno). Los claims los asigna la
    // Cloud Function setClientClaims (solo staff @agsanalitica.com puede invocarla).
    // Acceso SEGURO al claim: un staff no tiene la clave 'role', y el acceso por
    // punto a una clave ausente ABORTA la regla ("Property role is undefined").
    // Por eso se usa .get(clave, default).
    function esCliente() {
      return signedIn() && request.auth.token.get('role', '') == 'client';
    }
    // STAFF = autenticado con email VERIFICADO del dominio AGS. Fail-CLOSED: un token
    // sin email de dominio (cuenta Google ajena, cliente, anónimo) NO es staff, aunque
    // le falte el claim 'role'. El dominio se valida ACÁ (server-side), no solo en el
    // cliente: sin esto, cualquier cuenta Google que autentique contra la config pública
    // del bundle obtendría R/W total a la base interna. Acceso seguro al token con .get()
    // (una clave ausente abortaría la regla). matches() hace full-match sobre todo el email.
    function esStaff() {
      return signedIn()
        && request.auth.token.get('email_verified', false) == true
        && request.auth.token.get('email', '').lower().matches('.*@agsanalitica[.]com');
    }
    function miCliente(rid) {
      return esCliente() && request.auth.token.get('clienteId', '') == rid;
    }

    // ──────────────────────────────────────────────────────────────────────────
    // SUPERFICIES PÚBLICAS (sin login, por diseño). Acotadas al mínimo necesario.
    // ──────────────────────────────────────────────────────────────────────────

    // Tickets (leads): SOLO staff. El alta pública del QR pasó a la Cloud Function
    // `submitSoporte` (admin SDK, numeración atómica server-side), así que ya NO se
    // expone lectura ni alta anónima. (Fase A.2 del plan seguridad-qr-cliente.)
    match /leads/{leadId} {
      allow read, create, update, delete: if esStaff();
    }

    // PÚBLICO ACOTADO: firma remota (reportes-ot ?modo=firma).
    //   - read: el preview de la OT antes de firmar.
    //   - write anónimo: SOLO los campos de firma sobre una OT existente.
    // Se cerrará en Fase A.3 (link con token + vencimiento). Diferida: toca la app
    // de campo (superficie congelada) y se prueba en terreno aparte.
    match /reportes/{document=**} {
      allow read: if true;
      // Write pleno SOLO staff (auditoría 2026-07-17: `signedIn()` dejaba write total
      // a cualquier cuenta Google autenticada contra la config pública del bundle).
      // La firma remota anónima sigue por la rama acotada del diff.
      allow write: if esStaff()
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['signatureClient', 'signedAt', 'signedFrom']);
    }

    // Equipos (sistemas): lectura anónima CERRADA. El visitante anónimo del QR lee
    // la proyección segura vía Cloud Function `getEquipoPublico`. Staff lee todo;
    // un CLIENTE solo sus propios equipos. (Fase A.1 + C del plan.)
    // Nota: equipos legacy con clienteId null (solo establecimientoId) no son visibles
    // por esta regla para clientes — pendiente matcheo por establecimiento (Fase D).
    match /sistemas/{sistemaId} {
      allow read: if esStaff() || miCliente(resource.data.clienteId);
      allow write: if esStaff();
      match /modulos/{moduloId} {
        allow read, write: if esStaff();
      }
    }

    // collectionGroup('modulos') — sistema-modular busca sistemas por módulo/serie
    // (filtro de OTs, UAT 2026-07-17). El match anidado de arriba NO cubre queries
    // de collection group; sin este match, esa búsqueda muere al deployar estas rules.
    match /{path=**}/modulos/{moduloId} {
      allow read: if esStaff();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // COLECCIONES INTERNAS — solo STAFF de AGS (un token de cliente queda inerte).
    // ──────────────────────────────────────────────────────────────────────────

    // Colecciones legacy/futuro
    match /quotes/{quoteId}            { allow read, write: if esStaff(); }
    match /inventory/{itemId}          { allow read, write: if esStaff(); }
    match /appointments/{appointmentId}{ allow read, write: if esStaff(); }
    match /invoices/{invoiceId}        { allow read, write: if esStaff(); }

    // Clientes (+ contactos legacy)
    match /clientes/{clienteId} {
      allow read, write: if esStaff();
      match /contactos/{contactoId} {
        allow read, write: if esStaff();
      }
    }

    // Establecimientos (sedes/plantas por cliente)
    match /establecimientos/{establecimientoId} {
      allow read, write: if esStaff();
      match /contactos/{contactoId} {
        allow read, write: if esStaff();
      }
    }

    // Catálogos y otras colecciones del sistema modular
    match /categorias_equipo/{categoriaId}        { allow read, write: if esStaff(); }
    match /categorias_modulo/{categoriaId}        { allow read, write: if esStaff(); }
    match /presupuestos/{presupuestoId}           { allow read, write: if esStaff(); }
    match /categorias_presupuesto/{categoriaId}   { allow read, write: if esStaff(); }
    match /plantillas_texto_presupuesto/{plantillaId} { allow read, write: if esStaff(); }
    match /condiciones_pago/{condicionId}         { allow read, write: if esStaff(); }
    match /tipos_servicio/{tipoId}                { allow read, write: if esStaff(); }
    match /ordenes_compra/{ocId}                  { allow read, write: if esStaff(); }

    // Catálogo de Protocolos legacy (mantenido por compatibilidad)
    match /protocolCatalog/{catalogId}            { allow read, write: if esStaff(); }

    // Biblioteca de Tablas individuales (técnicos en reportes-ot leen autenticados)
    match /tableCatalog/{tableId}                 { allow read, write: if esStaff(); }
    match /tableProjects/{projectId}              { allow read, write: if esStaff(); }

    // Usuarios AGS (roles)
    match /usuarios/{uid} {
      allow read, write: if esStaff();
      match /fcmTokens/{tokenId} {
        allow read, write: if esStaff();
      }
    }

    // Adjuntos (metadata; binario en Firebase Storage)
    match /adjuntos/{adjuntoId}                   { allow read, write: if esStaff(); }

    // Instrumentos y Patrones (certificados de calibración)
    match /instrumentos/{instrumentoId}           { allow read, write: if esStaff(); }
    match /patrones/{patronId}                    { allow read, write: if esStaff(); }

    // Columnas cromatográficas (GC, HPLC)
    match /columnas/{columnaId}                   { allow read, write: if esStaff(); }

    // Marcas (catálogo compartido)
    match /marcas/{marcaId}                       { allow read, write: if esStaff(); }

    // ── Stock Module ──
    match /ingenieros/{ingenieroId}               { allow read, write: if esStaff(); }
    match /proveedores/{proveedorId}              { allow read, write: if esStaff(); }
    match /posicionesStock/{posicionId}           { allow read, write: if esStaff(); }
    match /articulos/{articuloId}                 { allow read, write: if esStaff(); }
    match /unidades/{unidadId}                    { allow read, write: if esStaff(); }
    match /minikits/{minikitId}                   { allow read, write: if esStaff(); }
    // Log INMUTABLE de auditoría de stock: solo alta y lectura. Editar/borrar
    // un asiento falsearía el historial (auditoría I8, 2026-07-20).
    match /movimientosStock/{movimientoId}        { allow read, create: if esStaff(); }
    match /remitos/{remitoId}                     { allow read, write: if esStaff(); }
    match /conceptos_servicio/{conceptoId}        { allow read, write: if esStaff(); }
    match /tiposEquipoPlantillas/{tipoId}         { allow read, write: if esStaff(); }
    match /consumibles_por_modulo/{moduloId}      { allow read, write: if esStaff(); }
    match /fichasPropiedad/{fichaId}              { allow read, write: if esStaff(); }
    match /loaners/{loanerId}                     { allow read, write: if esStaff(); }
    match /posiciones_arancelarias/{posicionId}   { allow read, write: if esStaff(); }
    match /requerimientos_compra/{requerimientoId}{ allow read, write: if esStaff(); }
    match /importaciones/{importacionId}          { allow read, write: if esStaff(); }
    match /agentesCarga/{agenteId}                { allow read, write: if esStaff(); }
    match /asignaciones/{asignacionId}            { allow read, write: if esStaff(); }

    // Agenda
    match /agendaEntries/{entryId}                { allow read, write: if esStaff(); }
    match /agendaNotas/{notaId}                   { allow read, write: if esStaff(); }
    // Previsiones = reservas del año siguiente para servicios regulatorios anuales
    // (OTs sin abrir). Mismo perfil de acceso que la agenda.
    match /agendaPrevisiones/{previsionId}        { allow read, write: if esStaff(); }

    // Workflow / OTs / facturación
    match /pendientes/{pendienteId}               { allow read, write: if esStaff(); }
    match /postas/{postaId}                        { allow read, write: if esStaff(); }
    match /viaticos/{viaticoId}                    { allow read, write: if esStaff(); }
    // OTs: staff completo; un CLIENTE solo lee las suyas (portal de cliente, Fase D).
    match /ordenes_trabajo/{otId} {
      allow read: if esStaff() || miCliente(resource.data.clienteId);
      allow write: if esStaff();
    }
    match /contratos/{contratoId}                  { allow read, write: if esStaff(); }
    match /solicitudesFacturacion/{solicitudId}    { allow read, write: if esStaff(); }
    match /ordenesCompraCliente/{ocId}             { allow read, write: if esStaff(); }
    // Control de facturas (cuentas a pagar): staff completo. Counter en /_counters/facturas.
    match /facturas/{facturaId}                    { allow read, write: if esStaff(); }

    // Counters atómicos (OT number, contrato number, etc.)
    match /_counters/{counterId}                   { allow read, write: if esStaff(); }

    // Misceláneos
    match /feriados/{feriadoId}                    { allow read, write: if esStaff(); }
    match /mailQueue/{mailId}                      { allow read, write: if esStaff(); }
    match /emailTemplates/{templateId}             { allow read, write: if esStaff(); }
    match /ingresosEmpresas/{ingresoId}            { allow read, write: if esStaff(); }
    match /dispositivos/{dispositivoId}            { allow read, write: if esStaff(); }
    match /vehiculos/{vehiculoId}                  { allow read, write: if esStaff(); }
    match /calificaciones_proveedor/{calificacionId} { allow read, write: if esStaff(); }
    match /catalogoSectores/{sectorId}             { allow read, write: if esStaff(); }
    match /certificadosIngeniero/{certId}          { allow read, write: if esStaff(); }
    match /adminConfig/{configId}                  { allow read, write: if esStaff(); }
    match /featureFlags/{flagId}                   { allow read, write: if esStaff(); }
    match /qfDocumentos/{qfId}                     { allow read, write: if esStaff(); }

    // Audit Log — inmutable: se crea pero nunca se modifica ni borra.
    match /audit_log/{logId} {
      allow read, create: if esStaff();
      allow update, delete: if false;
    }

    // Bloquear acceso a cualquier otra colección
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
