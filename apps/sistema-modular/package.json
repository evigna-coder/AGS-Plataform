{
  "name": "@ags/sistema-modular",
  "private": true,
  "version": "1.21.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 3001",
    "dev:electron": "concurrently -k -n \"VITE,ELECTRON\" -c \"blue,green\" \"vite --port 3001\" \"node scripts/wait-and-start-electron.cjs\" || exit 0",
    "build": "vite build && electron-builder --publish never",
    "build:web": "vite build",
    "build:desktop": "vite build --mode desktop && electron-builder --publish never",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "electron": "node scripts/start-electron.cjs",
    "electron:dev": "node scripts/start-electron.cjs --dev",
    "e2e:setup": "npx tsx e2e/global-setup.ts",
    "e2e": "npx playwright test --project=chromium",
    "e2e:headed": "set HEADED=1&& npx playwright test --project=chromium",
    "e2e:report": "npx tsx e2e/generate-report.ts",
    "e2e:full": "npx playwright test --project=chromium && npx tsx e2e/generate-report.ts",
    "test:stock-amplio": "tsx src/services/__tests__/stockAmplio.test.ts",
    "test:cuotas-facturacion": "tsx src/services/__tests__/cuotasFacturacion.test.ts",
    "test:equivalencias": "tsx src/services/__tests__/equivalencias.test.ts",
    "test:patron-bom": "tsx scripts/test-patron-bom.ts",
    "test:venta-loaner": "tsx scripts/test-venta-loaner.ts",
    "test:entregas": "tsx scripts/test-entregas.ts",
    "test:analitica": "tsx src/utils/analitica/__tests__/presupuestosMetrics.test.ts",
    "release:patch": "node scripts/release.cjs patch",
    "release:minor": "node scripts/release.cjs minor",
    "release:major": "node scripts/release.cjs major"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/electron": "^7.13.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "firebase": "^12.11.0",
    "google-auth-library": "^9.15.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-pdf-html": "^2.1.5",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "buffer": "^6.0.3",
    "concurrently": "^9.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "firebase-admin": "^13.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.agsanalitica.sistema-modular",
    "productName": "AGS Sistema Modular",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "AGS-Sistema-Modular-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AGS Sistema Modular",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "evigna-coder",
      "repo": "AGS-Plataform",
      "releaseType": "release",
      "private": true
    }
  }
}
