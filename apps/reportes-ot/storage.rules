rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permitir acceso a archivos del sistema modular
    match /sistema-modular/{allPaths=**} {
      allow read, write: if true; // ⚠️ Solo para desarrollo
      // TODO: Implementar autenticación y cambiar a:
      // allow read, write: if request.auth != null;
    }

    // Certificados e instrumentos (calibración y trazabilidad)
    match /certificados/{allPaths=**} {
      allow read, write: if true; // ⚠️ Solo para desarrollo
    }

    // Certificados de ingeniero (subidos desde sistema-modular, leídos desde reportes-ot)
    match /certificados-ingeniero/{allPaths=**} {
      allow read, write: if true; // ⚠️ Solo para desarrollo
    }

    // Adjuntos de reportes OT (fotos y archivos)
    match /adjuntos/{allPaths=**} {
      allow read, write: if true; // ⚠️ Solo para desarrollo
    }

    // Adjuntos de leads (fotos y archivos)
    match /leads/{allPaths=**} {
      allow read, write: if true; // ⚠️ Solo para desarrollo
    }

    // Reportes PDF generados
    match /reports/{allPaths=**} {
      allow read, write: if true; // ⚠️ Solo para desarrollo
    }

    // Bloquear acceso a otras rutas
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
