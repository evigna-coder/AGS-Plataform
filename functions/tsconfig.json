{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "moduleResolution": "node",
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noImplicitReturns": true
  },
  "compileOnSave": true,
  "include": ["src/**/*"],
  "exclude": ["lib", "node_modules", "src/__tests__/**/*"]
}
